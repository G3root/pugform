{
  "name": "@pugform/field-renderer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": ["dist"],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "clean": "rimraf .turbo node_modules dist",
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "preact": "^10.24.3",
    "preact-robot": "^1.0.0",
    "robot-hooks": "^1.0.0",
    "robot3": "^1.0.1"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "@pugform/database": "workspace:*",
    "tsup": "^8.3.5"
  }
}
