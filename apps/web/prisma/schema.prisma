// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator kysely {
  provider = "prisma-kysely"

  // Optionally provide a destination directory for the generated file
  // and a filename of your choice
  output       = "../app/generated"
  fileName     = "db-types.ts"
  // Optionally generate runtime enums to a separate file
  enumFileName = "enums.ts"
}

model Organization {
  id   String @id @default(cuid())
  name String

  createdAt DateTime
  updatedAt DateTime

  membership Membership[]
  Workspace  Workspace[]
  Form       Form[]
  FormPage   FormPage[]
  Session    Session[]
  Response   Response[]

  @@map("organization")
}

model Membership {
  id String @id @default(cuid())

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String

  lastAccessed DateTime

  user   User   @relation(fields: [userId], references: [id])
  userId String

  createdAt DateTime
  updatedAt DateTime
  Form      Form[]
  Session   Session[]
  Workspace Workspace[]

  @@map("membership")
}

enum GlobalRole {
  SUPERADMIN
  CUSTOMER
}

model User {
  id String @id @default(cuid())

  name         String
  email        String     @unique
  passwordHash String?
  role         GlobalRole @default(CUSTOMER)
  totpKey      Bytes?
  recoveryCode Bytes

  memberships Membership[]

  createdAt DateTime
  updatedAt DateTime
  Session   Session[]

  @@map("user")
}

model Session {
  id           String @id @default(cuid())
  userId       String
  membershipId String

  organizationId String
  expiresAt      Int

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  membership   Membership   @relation(fields: [membershipId], references: [id])

  createdAt DateTime
  updatedAt DateTime

  @@map("session")
}

model Workspace {
  id       String @id @default(cuid())
  name     String
  publicId String

  creator   Membership @relation(fields: [creatorId], references: [id])
  creatorId String

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String

  createdAt DateTime
  updatedAt DateTime
  Form      Form[]

  @@unique([publicId, organizationId])
  @@map("workspace")
}

enum FormLayout {
  CLASSIC
  CARD
}

enum FormStatus {
  DRAFT
  PUBLISHED
  PAUSED
}

model Form {
  id String @id @default(cuid())

  title       String
  description String?
  isActive    Boolean    @default(true)
  layout      FormLayout @default(CLASSIC)
  status      FormStatus @default(DRAFT)

  creator   Membership @relation(fields: [creatorId], references: [id])
  creatorId String

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String

  createdAt DateTime
  updatedAt DateTime

  FormPage FormPage[]
  Response Response[]
  Field    Field[]

  @@map("form")
}

model FormPage {
  id    String @id @default(cuid())
  index Int

  form   Form   @relation(fields: [formId], references: [id])
  formId String

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String

  createdAt DateTime
  updatedAt DateTime
  Field     Field[]

  @@map("formPage")
}

enum FieldType {
  SHORT_ANSWER
  NUMBER
  EMAIL
  LONG_ANSWER
  CHECKBOX
  MULTIPLE_CHOICE
  DROP_DOWN
  MULTI_SELECT
}

model Field {
  id          String  @id @default(cuid())
  label       String
  description String?
  placeholder String?

  type     FieldType
  required Boolean   @default(false)
  order    Int       @default(0)

  page       FormPage @relation(fields: [formPageId], references: [id], onDelete: Cascade)
  formPageId String

  form   Form   @relation(fields: [formId], references: [id])
  formId String

  options String[] @default([])

  createdAt DateTime
  updatedAt DateTime
  Answers   Answer[]

  @@map("field")
}

model Response {
  id String @id @default(cuid())

  form   Form   @relation(fields: [formId], references: [id])
  formId String

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String

  answers Answer[]

  createdAt DateTime
  updatedAt DateTime

  @@map("response")
}

model Answer {
  id String @id @default(cuid())

  question String
  answer   String
  type     FieldType
  order    Int

  field   Field?  @relation(fields: [fieldId], references: [id])
  fieldId String?

  Response   Response @relation(fields: [responseId], references: [id])
  responseId String

  createdAt DateTime
  updatedAt DateTime

  @@map("answer")
}

model Verification {
  id        String   @id @default(cuid())
  createdAt DateTime

  /// @kyselyType('onboarding' | 'member-invite' | 'email-verification')
  type String

  /// The thing we're trying to verify, e.g. a user's email or phone number
  target String

  /// The secret key used to generate the otp
  secret String

  /// The number of digits in the otp
  digits Int

  /// The number of seconds the otp is valid for
  period Int

  /// When it's safe to delete this verification
  expiresAt DateTime?

  @@unique([target, type])
  @@map("verification")
}
